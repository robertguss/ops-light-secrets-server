  },
  "oracle_mode": {
    "default": "frozen-fixture",
    "live_env": "OLSS_DIFFERENTIAL_LIVE_OPENBAO",
    "live_binary_env": "OLSS_OPENBAO_BIN",
    "notes": "Default CI uses frozen OpenBao-shaped oracle fixtures derived from the pinned OpenBao 2.6.0 KV v2 contract. Set OLSS_DIFFERENTIAL_LIVE_OPENBAO=1 with a verified bao binary to replay against a live reference server."
  }
}
