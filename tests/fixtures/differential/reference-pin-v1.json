{
  "schema": 1,
  "reference": {
    "product": "openbao",
    "role": "server",
    "version": "2.6.0",
    "binary": "bao",
    "archive": "openbao_2.6.0_linux_amd64.tar.gz",
    "format": "tar.gz",
    "url": "https://github.com/openbao/openbao/releases/download/v2.6.0/openbao_2.6.0_linux_amd64.tar.gz",
    "sha256": "42d83073f2d7a28ed408840138b0312111a8d4b2f5617086f009150336dad6d4",
    "provenance": "https://api.github.com/repos/openbao/openbao/releases/tags/v2.6.0",
    "configuration": {
      "mode": "dev",
      "kv_mount": "secret",
      "kv_version": 2,
      "from_scratch_per_case": true
